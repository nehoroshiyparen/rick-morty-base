# Порт, на котором запускается FastAPI-сервер
APP_PORT=7812

# URL фронтенда — используется в CORS, чтобы разрешить запросы с клиента
CLIENT_URL=http://localhost:5173

# URL основной базы данных (SQLite через aiosqlite)
# Внутри Docker путь /app/data/app.db соответствует ./backend/data/app.db на хосте
DATABASE_URL=sqlite+aiosqlite:////app/data/app.db

# URL тестовой базы данных — in-memory SQLite, создаётся заново для каждого теста
TEST_DATABASE_URL=sqlite+aiosqlite:///:memory:
